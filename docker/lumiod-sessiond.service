[Unit]
Description=Lumio OS session daemon (PAM, per-user agents)
After=dbus.service systemd-journald.service
Wants=dbus.service

[Service]
Type=simple
ExecStart=/usr/local/bin/lumiod sessiond
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
